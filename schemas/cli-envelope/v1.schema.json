{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.multiversa.dev/cli-envelope/v1",
  "title": "Multiversa CLI Envelope v1",
  "type": "object",
  "required": ["schema", "command", "cli_version", "ok"],
  "properties": {
    "schema": { "type": "string", "pattern": "^multiversa\\.[a-z][a-z0-9-]*/v[1-9][0-9]*$" },
    "command": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "cli_version": { "type": "string", "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$" },
    "ok": { "type": "boolean" },
    "data": {},
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "message": { "type": "string", "minLength": 1 },
        "hint": { "type": "string" },
        "details": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } }, "required": ["ok"] },
      "then": { "required": ["data"], "not": { "required": ["error"] } },
      "else": { "required": ["error"], "not": { "required": ["data"] } }
    }
  ],
  "additionalProperties": false
}
